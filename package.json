{
  "name": "snapsurf",
  "version": "1.0.0",
  "description": "Electron + TypeScript + React Browser",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:react": "vite",
    "build": "npm run build:electron && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "start": "npm run build:electron && electron ."
  },
  "keywords": [
    "electron",
    "browser",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@executeautomation/playwright-mcp-server": "^1.0.6",
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "playwright": "^1.56.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
